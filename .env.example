# Supply Chain Resilience Co-Pilot — environment template.
# Copy to .env and fill in. NEVER commit .env (see .gitignore).

# --- LLM backbone: Azure OpenAI via Azure AI Foundry (ADR-0008) ---
# Single provider. Failover is to a SECONDARY deployment (alt region/model),
# not a second provider.
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_DEPLOYMENT_PRIMARY=gpt-4o
AZURE_OPENAI_DEPLOYMENT_SECONDARY=gpt-4o-secondary
AZURE_OPENAI_SECONDARY_ENDPOINT=

# --- Chronos-2 forecasting (Azure AI Foundry managed endpoint; ADR-0004) ---
CHRONOS_ENDPOINT=
CHRONOS_API_KEY=

# --- Data source APIs ---
FRED_API_KEY=
MARINETRAFFIC_API_KEY=

# --- PostgreSQL (single instance, schema-separated; ADR-0006) ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=scrc
POSTGRES_PASSWORD=change-me
POSTGRES_DB=scrc

# --- MLflow (tracking, registry, audit trail) ---
MLFLOW_TRACKING_URI=http://mlflow:5000

# --- Observability: OTEL -> Opik (ADR-0005) ---
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OPIK_URL=http://opik:5173
OPIK_API_KEY=

# --- Governance ---
# Path/identifier for autonomy-threshold policy config (read from PostgreSQL at runtime).
AUTONOMY_POLICY_VERSION=default
